{
  "name": "aegis-maritime-system",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,frontend,dashboard1 -c blue,green,magenta \"npm --prefix aegis-backend run dev\" \"npm --prefix aegis-dashboard run dev\" \"npm --prefix dashboard-1 run dev\"",
    "dev:backend": "npm --prefix aegis-backend run dev",
    "dev:frontend": "npm --prefix aegis-dashboard run dev",
    "dev:dashboard1": "npm --prefix dashboard-1 run dev",
    "start:all": "npm run dev",
    "stop": "kill-port 3000 5000 5173",
    "stop:all": "npm run stop"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1"
  }
}
